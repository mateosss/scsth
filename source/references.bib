  file = {/home/mateo/Documents/apps/zotero-files/storage/XXAPLCNK/algo_affine_tracking.pdf;/home/mateo/Documents/apps/zotero-files/storage/J47UTQ2H/aa972b40c0f8e20b07e02d1fd320bc7ebadfdfc7.html}
